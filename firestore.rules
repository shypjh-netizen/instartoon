rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: characters
    // Fields:
    //   - userId: string (required)
    //   - imageUrl: string (required)
    //   - description: string (required)
    //   - style: string (required)
    //   - createdAt: timestamp (required)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidCharacter(data) {
      return data.userId is string &&
             data.name is string && data.name.size() < 100 &&
             data.imageUrl is string && data.imageUrl.size() < 2000000 &&
             data.description is string && data.description.size() < 1000 &&
             data.style is string &&
             data.createdAt is timestamp;
    }

    match /characters/{charId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidCharacter(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
